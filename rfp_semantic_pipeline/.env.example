APP_NAME=rfp_semantic_pipeline
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_PORT=8501
DATA_DIR=./data
SQLITE_PATH=./data/rfp_pipeline.db
TAXONOMY_PATH=./config/taxonomy.yaml
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=gpt-oss-20b
LLM_API_KEY=lm-studio
EMBEDDING_PROVIDER=local_sentence_transformer
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
FAISS_INDEX_PATH=./data/vectorstores/chunks.faiss
MAX_CHUNK_CHARS=1200
CHUNK_OVERLAP_CHARS=200
